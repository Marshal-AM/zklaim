{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../wasm/**/*.json"]
}
